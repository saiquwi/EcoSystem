<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EcoSystem</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <%- include('../../partials/header') %>
    
    <main class="main">
        <div class="container">
            
            <div class="admin-header">
                <div class="header-left">
                    <a href="/admin" class="btn btn-outline btn-small">← Back to Panel</a>
                    <h1>Manage Problems</h1>
                </div>
            </div>
            
            <!-- Filters -->
            <div class="filters-bar">
                <div class="filter-group">
                    <label>Category:</label>
                    <select id="categoryFilter" class="form-control">
                        <option value="all" <%= currentCategory === 'all' ? 'selected' : '' %>>All</option>
                        <% categories.forEach(function(cat) { %>
                            <option value="<%= cat.title %>" <%= currentCategory === cat.title ? 'selected' : '' %>>
                                <%= cat.title %>
                            </option>
                        <% }); %>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label>Status:</label>
                    <select id="statusFilter" class="form-control">
                        <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All</option>
                        <option value="pending" <%= currentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="confirmed" <%= currentStatus === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                        <option value="in_progress" <%= currentStatus === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                        <option value="completed" <%= currentStatus === 'completed' ? 'selected' : '' %>>Completed</option>
                        <option value="closed" <%= currentStatus === 'closed' ? 'selected' : '' %>>Closed</option>
                    </select>
                </div>
                
                <div class="filter-group search-group">
                    <label>Search:</label>
                    <input type="text" id="searchProblems" placeholder="Search by title..." class="form-control">
                </div>
            </div>
            
            <!-- Problems Table -->
            <div class="admin-card">
                <div class="card-header">
                    <h3>All Problems (<span id="problemCount"><%= problems.length %></span>)</h3>
                </div>
                
                <div class="table-responsive">
                    <table class="admin-table" id="problemsTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Severity</th>
                                <th>Author</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% problems.forEach(function(problem) { %>
                                <tr data-title="<%= problem.title %>">
                                    <td><%= problem.id %></td>
                                    <td><%= problem.title.length > 50 ? problem.title.substring(0, 50) + '...' : problem.title %></td>
                                    <td>
                                        <span class="category-badge category-<%= problem.category %>">
                                            <%= problem.category %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="status-badge status-<%= problem.status %>">
                                            <%= problem.status %>
                                        </span>
                                    </td>
                                    <td><%= problem.severity %>/10</td>
                                    <td><%= problem.author_name || 'Anonymous' %></td>
                                    <td><%= new Date(problem.created_at).toLocaleDateString('ru-RU') %></td>
                                    <td>
                                        <button class="btn btn-danger btn-small delete-problem" data-problem-id="<%= problem.id %>" data-problem-title="<%= problem.title %>">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                
                <% if (problems.length === 0) { %>
                    <div class="empty-state">
                        <p>No problems found</p>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
    
    <script src="/js/admin-problems.js"></script>
    <script src="/js/notifications.js"></script>
</body>
</html>