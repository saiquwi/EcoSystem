<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EcoSystem</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <%- include('../../partials/header') %>
    
    <main class="main">
        <div class="container">
            <div class="admin-header">
                <div class="header-left">
                    <a href="/admin" class="btn btn-outline btn-small">← Back to Panel</a>
                    <h1>Manage Users</h1>
                </div>
            </div>
            
            <!-- Stats Summary -->
            <div class="stats-row">
                <div class="stat-mini">
                    <span class="stat-mini-label">Total Users</span>
                    <span class="stat-mini-value"><%= users.length %></span>
                </div>
                <div class="stat-mini">
                    <span class="stat-mini-label">Volunteers</span>
                    <span class="stat-mini-value"><%= users.filter(u => u.role === 'volunteer').length %></span>
                </div>
                <div class="stat-mini">
                    <span class="stat-mini-label">Admins</span>
                    <span class="stat-mini-value"><%= users.filter(u => u.role === 'admin').length %></span>
                </div>
                <div class="header-right">
                    <button id="newUserBtn" class="btn btn-primary">+ New User</button>
                </div>
            </div>
            
            <!-- Users Table -->
            <div class="admin-card">
                <div class="card-header">
                    <h3>All Users</h3>
                    <div class="search-box">
                        <input type="text" id="searchUsers" placeholder="Search by name or email..." class="form-control">
                    </div>
                </div>
                
                <div class="table-responsive">
                    <table class="admin-table" id="usersTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Joined</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(function(user) { %>
                                <tr data-name="<%= user.name || '' %>" data-email="<%= user.email %>">
                                    <td><%= user.id %></td>
                                    <td><%= user.name || '-' %></td>
                                    <td><%= user.email %></td>
                                    <td>
                                        <span class="role-badge role-<%= user.role %>">
                                            <%= user.role === 'admin' ? 'Admin' : 'Volunteer' %>
                                        </span>
                                    </td>
                                    <td><%= new Date(user.created_at).toLocaleDateString('ru-RU') %></td>
                                    <td>
                                        <% if (user.role !== 'admin') { %>
                                            <button class="btn btn-danger btn-small delete-user" data-user-id="<%= user.id %>" data-user-name="<%= user.name || user.email %>">
                                                Delete
                                            </button>
                                        <% } else { %>
                                            <span class="text-muted">—</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- New User Modal -->
    <div class="modal" id="newUserModal" data-show="<%= showModal ? 'true' : 'false' %>">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Create New User</h3>
                <button class="modal-close" id="closeModalBtn">&times;</button>
            </div>
            <form method="POST" action="/admin/users" class="admin-form">
                <div class="form-group">
                    <label for="email" class="form-label">Email Address *</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        value="<%= formData.email || '' %>"
                        class="form-control <%= errors && errors.email ? 'is-invalid' : '' %>"
                        placeholder="you@example.com"
                        required
                    >
                    <% if (errors && errors.email) { %>
                        <div class="invalid-feedback">
                            <% if (Array.isArray(errors.email)) { %>
                                <% errors.email.forEach(function(err) { %>
                                    <div>• <%= err %></div>
                                <% }); %>
                            <% } else { %>
                                <div><%= errors.email %></div>
                            <% } %>
                        </div>
                    <% } %>
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">Password *</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        autocomplete="new-password"
                        class="form-control <%= errors && errors.password ? 'is-invalid' : '' %>"
                        placeholder="Create a strong password"
                        required
                    >
                    <% if (errors && errors.password) { %>
                        <div class="invalid-feedback">
                            <% if (Array.isArray(errors.password)) { %>
                                <% errors.password.forEach(function(err) { %>
                                    <div>• <%= err %></div>
                                <% }); %>
                            <% } else { %>
                                <div><%= errors.password %></div>
                            <% } %>
                        </div>
                    <% } %>
                    <div class="form-text">Minimum 8 characters with letters, numbers and special characters</div>
                </div>
                
                <div class="form-group">
                    <label for="confirmPassword" class="form-label">Confirm Password *</label>
                    <input 
                        type="password" 
                        id="confirmPassword" 
                        name="confirmPassword" 
                        autocomplete="new-password"
                        class="form-control <%= errors && errors.confirmPassword ? 'is-invalid' : '' %>"
                        placeholder="Confirm your password"
                        required
                    >
                    <% if (errors && errors.confirmPassword) { %>
                        <div class="invalid-feedback">
                            <% if (Array.isArray(errors.confirmPassword)) { %>
                                <% errors.confirmPassword.forEach(function(err) { %>
                                    <div>• <%= err %></div>
                                <% }); %>
                            <% } else { %>
                                <div><%= errors.confirmPassword %></div>
                            <% } %>
                        </div>
                    <% } %>
                </div>
                
                <div class="form-group">
                    <label for="name" class="form-label">Full Name</label>
                    <input 
                        type="text" 
                        id="name" 
                        name="name" 
                        value="<%= formData.name || '' %>"
                        class="form-control <%= errors && errors.name ? 'is-invalid' : '' %>"
                        placeholder="John Doe"
                    >
                    <% if (errors && errors.name) { %>
                        <div class="invalid-feedback">
                            <% if (Array.isArray(errors.name)) { %>
                                <% errors.name.forEach(function(err) { %>
                                    <div>• <%= err %></div>
                                <% }); %>
                            <% } else { %>
                                <div><%= errors.name %></div>
                            <% } %>
                        </div>
                    <% } %>
                    <div class="form-text">Optional</div>
                </div>
                
                <div class="form-group">
                    <label for="role" class="form-label">Role *</label>
                    <select id="role" name="role" class="form-control" required>
                        <option value="volunteer" <%= formData.role === 'volunteer' ? 'selected' : '' %>>Volunteer</option>
                        <option value="admin" <%= formData.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="bio" class="form-label">Bio</label>
                    <textarea 
                        id="bio" 
                        name="bio" 
                        rows="3"
                        class="form-control <%= errors && errors.bio ? 'is-invalid' : '' %>"
                        placeholder="Tell us about yourself..."
                    ><%= formData.bio || '' %></textarea>
                    <% if (errors && errors.bio) { %>
                        <div class="invalid-feedback">
                            <% if (Array.isArray(errors.bio)) { %>
                                <% errors.bio.forEach(function(err) { %>
                                    <div>• <%= err %></div>
                                <% }); %>
                            <% } else { %>
                                <div><%= errors.bio %></div>
                            <% } %>
                        </div>
                    <% } %>
                    <div class="form-text">Optional. Maximum 500 characters</div>
                </div>
                
                <div class="form-actions">
                    <button type="button" class="btn btn-outline" id="cancelModalBtn">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create User</button>
                </div>
            </form>
        </div>
    </div>
    
    <script src="/js/admin-users.js"></script>
    <script src="/js/notifications.js"></script>
</body>
</html>