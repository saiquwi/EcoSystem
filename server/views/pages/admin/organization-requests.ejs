<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EcoSystem</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <%- include('../../partials/header') %>
    
    <main class="main">
        <div class="container">
            <div class="admin-header">
                <div class="header-left">
                    <a href="/admin" class="btn btn-outline btn-small">← Back to Panel</a>
                    <h1>Organization Creation Requests</h1>
                </div>
            </div>

            <!-- Filter by Status -->
            <div class="filter-bar">
                <button class="filter-chip active" data-status="all">All</button>
                <button class="filter-chip" data-status="pending">Pending</button>
                <button class="filter-chip" data-status="rejected">Rejected</button>
            </div>
            
            <div class="admin-card">
                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Organization Name</th>
                                <th>Email</th>
                                <th>Requested By</th>
                                <th>Status</th>
                                <th>Submitted</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="requestsTableBody">
                            <% requests.forEach(function(req) { %>
                                <tr data-status="<%= req.status %>">
                                    <td><%= req.id %></td>
                                    <td><%= req.name %></td>
                                    <td><%= req.email %></td>
                                    <td><%= req.user_name %> (<%= req.user_email %>)</td>
                                    <td>
                                        <span class="status-badge status-<%= req.status %>">
                                            <%= req.status %>
                                        </span>
                                    </td>
                                    <td><%= new Date(req.created_at).toLocaleDateString('ru-RU') %></td>
                                    <td>
                                        <% if (req.status === 'pending') { %>
                                            <button class="btn btn-success btn-small approve-request" data-id="<%= req.id %>" data-name="<%= req.name %>">
                                                Approve
                                            </button>
                                            <button class="btn btn-danger btn-small reject-request" data-id="<%= req.id %>" data-name="<%= req.name %>">
                                                Reject
                                            </button>
                                        <% } else { %>
                                            <button class="btn btn-success btn-small approve-request" data-id="<%= req.id %>" data-name="<%= req.name %>">
                                                Approve
                                            </button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
    
    <script src="/js/notifications.js"></script>
    <script src="/js/admin-requests.js"></script>
</body>
</html>