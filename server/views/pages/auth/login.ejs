<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EcoSystem</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <%- include('../../partials/header') %>
    
    <main class="main">
        <div class="container">
            <div class="auth-card">
                <div class="auth-header">
                    <div class="auth-icon">🌍</div>
                    <h1 class="auth-title">Welcome Back</h1>
                    <p class="auth-subtitle">Sign in to continue to EcoSystem</p>
                </div>
                
                <% if (locals.errors && errors.general) { %>
                    <div class="alert alert-error">
                        <strong>Error!</strong>
                        <% if (Array.isArray(errors.general)) { %>
                            <% errors.general.forEach(function(err) { %>
                                <div>• <%= err %></div>
                            <% }); %>
                        <% } else { %>
                            <div><%= errors.general %></div>
                        <% } %>
                    </div>
                <% } %>
                
                <form method="POST" action="/auth/login" class="auth-form">
                    <div class="form-group">
                        <label for="email" class="form-label">Email Address</label>
                        <input 
                            type="email" 
                            id="email" 
                            name="email" 
                            value="<%= formData.email || '' %>"
                            class="form-control <%= errors && errors.email ? 'is-invalid' : '' %>"
                            placeholder="you@example.com"
                            required
                        >
                        <% if (errors && errors.email) { %>
                            <div class="invalid-feedback">
                                <% if (Array.isArray(errors.email)) { %>
                                    <% errors.email.forEach(function(err) { %>
                                        <div>• <%= err %></div>
                                    <% }); %>
                                <% } else { %>
                                    <div><%= errors.email %></div>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="form-group">
                        <label for="password" class="form-label">Password</label>
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            class="form-control <%= errors && errors.password ? 'is-invalid' : '' %>"
                            placeholder="••••••••"
                            required
                        >
                        <% if (errors && errors.password) { %>
                            <div class="invalid-feedback">
                                <% if (Array.isArray(errors.password)) { %>
                                    <% errors.password.forEach(function(err) { %>
                                        <div>• <%= err %></div>
                                    <% }); %>
                                <% } else { %>
                                    <div><%= errors.password %></div>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                    
                    <button type="submit" class="btn btn-primary btn-block btn-large">
                        Sign In
                    </button>
                </form>
                
                <div class="divider"></div>
                
                <p class="auth-footer">
                    Don't have an account? <a href="/auth/register">Create Account</a>
                </p>
            </div>
        </div>
    </main>
</body>
</html>