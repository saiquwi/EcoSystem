<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | EcoSystem</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/organization.css">
    <link rel="stylesheet" href="/css/gallery.css">
    <link rel="stylesheet" href="/css/posts.css">
</head>
<body>
    <%- include('../partials/header') %>
    
    <main class="main">
        <div class="container">
            <div class="back-nav">
                <a href="<%= returnTo %>" class="btn btn-outline btn-small">
                    ← Back
                </a>
            </div>

            <!-- Organization Header -->
            <div class="org-header">
                <div class="org-info">
                    <h1 class="org-name"><%= organization.name %></h1>
                    <p class="org-email"><%= organization.email %></p>
                    <% if (organization.website) { %>
                        <p class="org-website">🌐 <a href="<%= organization.website %>" target="_blank"><%= organization.website %></a></p>
                    <% } %>
                    <p class="org-description"><%= organization.description || 'No description provided' %></p>
                </div>
                <div class="org-actions">
                    <% if (isAuthenticated) { %>
                        <button class="follow-btn <%= isFollowing ? 'following' : '' %>" data-org-id="<%= organization.id %>">
                            <%= isFollowing ? 'Unfollow' : 'Follow' %>
                        </button>
                    <% } %>
                </div>
            </div>

            <!-- Tabs -->
            <div class="org-tabs">
                <button class="tab-btn active" data-tab="posts">Posts</button>
                <button class="tab-btn" data-tab="events">Events</button>
            </div>

            <!-- Posts Tab -->
            <div id="postsTab" class="tab-content active">
                <div class="posts-header">
                    <h2>Posts</h2>
                    <% if (isStaff) { %>
                        <button id="addPostBtn" class="btn btn-primary btn-small">+ Add Post</button>
                    <% } %>
                </div>
                
                <!-- Форма создания поста (скрыта по умолчанию) -->
                <div id="createPostFormContainer" class="create-post-container" style="display: none;">
                    <form id="createPostForm" class="create-post-form">
                        <input type="hidden" id="postOrgId" value="<%= organization.id %>">
                        <div class="form-group">
                            <textarea id="postContent" name="content" rows="3" class="form-control" placeholder="What's happening?" required></textarea>
                        </div>
                        <div class="form-group">
                            <div class="file-input-wrapper">
                                <input type="file" id="postPhotos" name="photos" multiple accept="image/*" style="display: none;">
                                <button type="button" id="selectPhotosBtn" class="btn btn-outline">Choose Photos</button>
                                <span id="postFileCount" class="file-count">0 / 5 files selected</span>
                            </div>
                            <div id="postPhotoPreview" class="photo-preview"></div>
                        </div>
                        <div class="form-actions">
                            <button type="button" id="cancelPostBtn" class="btn btn-outline">Cancel</button>
                            <button type="submit" class="btn btn-primary">Post</button>
                        </div>
                    </form>
                </div>
                
                <div id="orgPostsList" class="posts-list">
                    <!-- Posts will be loaded dynamically -->
                </div>
            </div>
            
            <!-- Events Tab -->
            <div id="eventsTab" class="tab-content" style="display: none;">
                <div class="events-header">
                    <h2>Events</h2>
                    <% if (isStaff) { %>
                        <button id="addEventFromOrgBtn" class="btn btn-primary btn-small">+ Add Event</button>
                    <% } %>
                </div>
                <div id="orgEventsList" class="events-list">
                    <!-- Events will be loaded dynamically -->
                </div>
            </div>
        </div>
    </main>
    
    <div id="app-data" 
         data-current-user-id="<%= user ? user.id : '' %>" 
         data-is-authenticated="<%= isAuthenticated %>"
         style="display: none;">
    </div>

    <div id="org-data" 
        data-org-id="<%= organization.id %>"
        data-is-staff="<%= isStaff %>"
        data-org-name="<%= organization.name %>"
        style="display: none;">
    </div>

    <!-- Add Event Modal -->
    <div class="modal" id="eventModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Create New Event</h3>
                <button class="modal-close" id="closeEventModal">&times;</button>
            </div>
            <form id="eventForm" class="event-form">
                <div class="form-group">
                    <label for="eventTitle" class="form-label">Title *</label>
                    <input type="text" id="eventTitle" name="title" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label for="eventDescription" class="form-label">Description</label>
                    <textarea id="eventDescription" name="description" rows="3" class="form-control"></textarea>
                </div>
                
                <div class="form-group">
                    <label for="eventOrganization" class="form-label">Organization *</label>
                    <select id="eventOrganization" name="organizationId" class="form-control" required>
                        <option value="">Select organization...</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="eventDate" class="form-label">Event Date & Time *</label>
                    <div class="datetime-row">
                        <input type="date" id="eventDate" name="eventDate" class="form-control" required>
                        <input type="time" id="eventTime" name="eventTime" class="form-control" required>
                    </div>
                    <div id="eventTimezoneInfo" class="timezone-info" style="font-size: 0.8rem; color: var(--gray); margin-top: 5px;">
                        UTC (will update after selecting location)
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="eventMaxVolunteers" class="form-label">Max Volunteers</label>
                    <input type="number" id="eventMaxVolunteers" name="maxVolunteers" class="form-control" placeholder="Unlimited if empty">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Location *</label>
                    <button type="button" id="chooseEventLocationBtn" class="btn btn-outline btn-block">📍 Choose location on the map</button>
                    <div class="location-info" id="eventLocationInfo">
                        <p class="text-muted">No location selected</p>
                    </div>
                    <input type="hidden" id="eventLat" name="latitude" required>
                    <input type="hidden" id="eventLng" name="longitude" required>
                </div>
                
                <div class="form-actions">
                    <button type="button" class="btn btn-outline" id="cancelEventModalBtn">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Event</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Photo Gallery Modal -->
    <div class="modal" id="photoGalleryModal" style="display: none;">
        <div class="gallery-modal-content">
            <div class="gallery-header">
                <button class="gallery-close" id="closeGalleryModal">&times;</button>
            </div>
            <div class="gallery-container">
                <button class="gallery-nav prev" id="galleryPrev">❮</button>
                <div class="gallery-image-container">
                    <img id="galleryImage" src="" alt="Gallery image">
                </div>
                <button class="gallery-nav next" id="galleryNext">❯</button>
            </div>
            <div class="gallery-counter" id="galleryCounter"></div>
        </div>
    </div>
    
    <script src="/js/gallery.js"></script>
    <script src="/js/notifications.js"></script>
    <script src="/js/posts.js"></script>
    <script src="/js/organization.js"></script>
</body>
</html>