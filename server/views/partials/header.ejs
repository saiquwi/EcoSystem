<header class="header">
    <div class="container">
        <nav class="nav">
            <a href="/" class="logo">
                <span class="logo-icon">🌍</span>
                <span class="logo-text">EcoSystem</span>
            </a>
            
            <div class="nav-links">
                <% if (isAuthenticated) { %>
                    <% if (isAdmin) { %>
                        <a href="/admin" class="nav-link">Admin Panel</a>
                    <% } else { %>
                        <a href="/organizations/feed" class="nav-link">Feed</a>
                        <a href="/organizations/my-organizations" class="nav-link">My Organizations</a>
                        <a href="/dashboard" class="nav-link">Dashboard</a>
                    <% } %>
                    <a href="/map" class="nav-link">Map</a>
                    <div class="user-menu">
                        <a href="/auth/profile" class="nav-link user-name">
                            👤 <%= user ? user.name : 'Profile' %>
                        </a>
                        <a href="/auth/logout" class="btn btn-outline btn-small">Logout</a>
                    </div>
                <% } else { %>
                    <a href="/" class="nav-link">Home</a>
                    <a href="/map" class="nav-link">Map</a>
                    <a href="/auth/login" class="btn btn-outline btn-small">Login</a>
                    <a href="/auth/register" class="btn btn-primary btn-small">Sign Up</a>
                <% } %>
            </div>
            
            <button class="mobile-menu-btn" id="mobileMenuBtn">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>
    </div>
</header>

<link rel="stylesheet" href="/css/header.css">
<script src="/js/header.js" defer></script>